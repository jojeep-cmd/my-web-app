---
interface Props {
    title: string;
}

const { title } = Astro.props;

// Get current URL path
const currentPath = new URL(Astro.request.url).pathname;

// Define navigation links
const navLinks = [
    { href: "/", label: "🏠 Trang chủ", path: "/" },
    { href: "/about", label: "👨‍💻 Về tôi", path: "/about" },
    { href: "/contact", label: "📧 Liên hệ", path: "/contact" },
];

// Check if link is active
const isActive = (href: string) => {
    if (href === "/" && currentPath === "/") return true;
    if (href !== "/" && currentPath.startsWith(href)) return true;
    return false;
};
---

<!doctype html>
<html lang="vi">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta
            name="description"
            content="Web app được tạo với Astro + Svelte trên Cloudflare Workers"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{title}</title>
    </head>
    <body>
        <nav class="navbar">
            <div class="navbar-container">
                <div class="navbar-brand">
                    <a href="/" class="brand-link">🚀 My Web App</a>
                </div>

                <button
                    class="menu-toggle"
                    id="menuToggle"
                    aria-label="Toggle menu"
                >
                    <span class="hamburger"></span>
                    <span class="hamburger"></span>
                    <span class="hamburger"></span>
                </button>

                <ul class="nav-menu" id="navMenu">
                    {
                        navLinks.map((link) => (
                            <li class="nav-item">
                                <a
                                    href={link.href}
                                    class={`nav-link ${isActive(link.href) ? "active" : ""}`}
                                >
                                    {link.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>
        </nav>

        <main>
            <slot />
        </main>

        <footer>
            <p>
                Được tạo với ❤️ bằng Astro + Svelte trên Cloudflare Workers —
                2026
            </p>
        </footer>

        <script>
            // Mobile menu toggle
            const menuToggle = document.getElementById("menuToggle");
            const navMenu = document.getElementById("navMenu");

            if (menuToggle && navMenu) {
                menuToggle.addEventListener("click", () => {
                    navMenu.classList.toggle("active");
                    menuToggle.classList.toggle("active");
                });

                // Close menu when link is clicked
                const navLinks = navMenu.querySelectorAll(".nav-link");
                navLinks.forEach((link) => {
                    link.addEventListener("click", () => {
                        navMenu.classList.remove("active");
                        menuToggle.classList.remove("active");
                    });
                });
            }
        </script>
    </body>
</html>

<style is:global>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family:
            -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        line-height: 1.6;
        color: #333;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    /* Navbar Styles */
    .navbar {
        background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
        padding: 0;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    .navbar-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 70px;
        width: 100%;
    }

    .navbar-brand {
        display: flex;
        align-items: center;
    }

    .brand-link {
        color: white;
        text-decoration: none;
        font-size: 1.3rem;
        font-weight: 700;
        transition: opacity 0.3s ease;
    }

    .brand-link:hover {
        opacity: 0.8;
    }

    /* Navigation Menu */
    .nav-menu {
        display: flex;
        list-style: none;
        gap: 0;
        align-items: center;
    }

    .nav-item {
        margin: 0;
    }

    .nav-link {
        display: block;
        color: #e0e7ff;
        text-decoration: none;
        font-weight: 500;
        font-size: 1rem;
        padding: 0.5rem 1.25rem;
        transition: all 0.3s ease;
        position: relative;
        border-bottom: 3px solid transparent;
    }

    .nav-link:hover {
        color: #fbbf24;
        background: rgba(255, 255, 255, 0.1);
    }

    .nav-link.active {
        color: #fbbf24;
        background: rgba(255, 255, 255, 0.15);
        border-bottom-color: #fbbf24;
    }

    /* Hamburger Menu Toggle */
    .menu-toggle {
        display: none;
        flex-direction: column;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        gap: 5px;
    }

    .hamburger {
        width: 25px;
        height: 3px;
        background: white;
        border-radius: 2px;
        transition: all 0.3s ease;
        display: block;
    }

    .menu-toggle.active .hamburger:nth-child(1) {
        transform: rotate(45deg) translate(10px, 10px);
    }

    .menu-toggle.active .hamburger:nth-child(2) {
        opacity: 0;
    }

    .menu-toggle.active .hamburger:nth-child(3) {
        transform: rotate(-45deg) translate(7px, -7px);
    }

    /* Main Content */
    main {
        flex: 1;
        padding: 2rem;
        max-width: 900px;
        margin: 0 auto;
        width: 100%;
    }

    /* Footer */
    footer {
        background: #f3f4f6;
        text-align: center;
        padding: 1.5rem;
        color: #666;
        font-size: 0.9rem;
        border-top: 1px solid #e5e7eb;
    }

    /* Responsive Design - Tablet (768px) */
    @media (max-width: 768px) {
        .navbar-container {
            height: 60px;
        }

        .brand-link {
            font-size: 1.1rem;
        }

        .menu-toggle {
            display: flex;
        }

        .nav-menu {
            position: absolute;
            top: 60px;
            left: 0;
            right: 0;
            flex-direction: column;
            background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
            gap: 0;
        }

        .nav-menu.active {
            max-height: 300px;
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
        }

        .nav-item {
            width: 100%;
        }

        .nav-link {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            border-right: 4px solid transparent;
        }

        .nav-link.active {
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            border-right-color: #fbbf24;
        }

        main {
            padding: 1.5rem;
        }
    }

    /* Responsive Design - Mobile (480px) */
    @media (max-width: 480px) {
        .navbar-container {
            padding: 0 0.75rem;
            height: 56px;
        }

        .brand-link {
            font-size: 1rem;
        }

        .nav-menu.active {
            max-height: 250px;
        }

        .nav-link {
            padding: 0.75rem 1rem;
            font-size: 0.95rem;
        }

        main {
            padding: 1rem;
        }

        footer {
            padding: 1rem 0.75rem;
            font-size: 0.85rem;
        }
    }
</style>
